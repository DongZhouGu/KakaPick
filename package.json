{
  "name": "burstpick",
  "version": "1.0.0",
  "description": "Local-first RAW+JPEG photo culling for macOS",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "tsx watch src/server/dev.ts",
    "build": "tsc -p tsconfig.node.json && vite build",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test:e2e": "env -u NO_COLOR playwright test",
    "test:metadata-smoke": "vitest run tests/integration/metadata-safety.smoke.test.ts",
    "desktop:start": "pnpm build && electron .",
    "desktop:pack": "pnpm build && electron-builder --mac dir --arm64 --publish never",
    "desktop:dist": "pnpm build && electron-builder --mac dmg --arm64 --publish never"
  },
  "keywords": [
    "photo-culling",
    "raw",
    "lightroom",
    "macos"
  ],
  "author": "KakaPick contributors",
  "license": "MIT",
  "engines": {
    "node": ">=20.3"
  },
  "packageManager": "pnpm@11.7.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.7.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "build": {
    "appId": "com.burstpick.app",
    "productName": "KakaPick",
    "asar": true,
    "asarUnpack": [
      "node_modules/@img/sharp-darwin-arm64/lib/**/*",
      "node_modules/@img/sharp-libvips-darwin-arm64/lib/**/*",
      "node_modules/exiftool-vendored.pl/**/*"
    ],
    "afterPack": "scripts/adhoc-sign.cjs",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.d.ts",
      "!dist/**/*.map",
      "!node_modules/**/*.map",
      "!node_modules/**/*.spec.*",
      "!node_modules/**/test/**/*",
      "!node_modules/**/tests/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.photography",
      "hardenedRuntime": false,
      "icon": "build/AppIcon.png",
      "identity": null,
      "minimumSystemVersion": "13.0",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "artifactName": "KakaPick-${version}-${arch}.${ext}",
      "sign": false
    }
  },
  "dependencies": {
    "exiftool-vendored": "35.21.0",
    "express": "5.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.34.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "8.57.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/express": "5.0.6",
    "@types/node": "20.3.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "7.2.0",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "4.1.10",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "eslint": "8.57.1",
    "jsdom": "26.1.0",
    "playwright": "1.61.1",
    "supertest": "7.2.2",
    "tsx": "4.23.0",
    "typescript": "5.5.4",
    "typescript-eslint": "7.18.0",
    "vite": "6.4.3",
    "vitest": "4.1.10"
  }
}
